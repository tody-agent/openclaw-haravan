{
  "name": "@haravan-master/openclaw-haravan-ops-plugin",
  "version": "0.1.0",
  "description": "OpenClaw plugin: Haravan shop ops tools (same surface as lean MCP).",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": ["dist", "openclaw.plugin.json"],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "prepack": "npm run build"
  },
  "dependencies": {
    "@haravan-master/core": "*",
    "@haravan-master/haravan-ops-dispatch": "*",
    "@sinclair/typebox": "^0.34.28",
    "openclaw": "2026.4.2"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.3.3"
  },
  "openclaw": {
    "extensions": ["./dist/index.js"],
    "compat": {
      "pluginApi": ">=2026.4.0",
      "minGatewayVersion": "2026.4.0"
    },
    "build": {
      "openclawVersion": "2026.4.2",
      "pluginSdkVersion": "2026.4.2"
    }
  }
}
